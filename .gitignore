# macOS
.DS_Store

# Aider AI assistant
.aider*

# FZF (generated by install script, homebrew path differs by architecture)
.fzf.zsh
.fzf.bash

# Environment files (should not be shared)
.env
.envrc

# Local machine-specific configs (not shared between machines)
*.local
.zshrc.local
.bashrc.local
.config/fish/config.local.fish
.config/nushell/config.local.nu

# Fish shell auto-generated migration files
.config/fish/conf.d/fish_frozen_*.fish
