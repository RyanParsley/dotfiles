{
  "$schema": "https://opencode.ai/config.json",
  "theme": "nord",
  "mcp": {
    "dokploy-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ahdev/dokploy-mcp"
      ],
      "environment": {
        "DOKPLOY_URL": "https://dokploy.fretsome.com/api",
        "DOKPLOY_API_KEY": "{env:DOKPLOY_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-3n-e4b": {
          "name": "Gemma 3n-e4b (local)"
        },
        "ishumilin/deepseek-r1-coder-tools:8b": {
          "name": "Deepseek Coder Tools (8b)"
        },
        "olmo2": {
          "name": "OLMo 2"
        },
        "qwen3": {
          "name": "Qwen 3"
        },
        "qwen3-coder": {
          "name": "Qwen 3 Coder"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "kimi-k2.5:cloud": {
          "_launch": true,
          "name": "kimi-k2.5:cloud"
        },
        "olmo2": {
          "name": "OLMo 2",
          "tool_call": true
        },
        "granite3-dense": {
          "name": "Granite 3 Dense"
        },
        "maryasov/qwen2.5-coder-cline": {
          "name": "Maryasov Qwen 2.5 Coder Cline"
        },
        "ishumilin/deepseek-r1-coder-tools:8b": {
          "name": "Deepseek Coder Tools (8b)"
        },
        "llama2": {
          "name": "Llama 2"
        },
        "llama3.1": {
          "name": "Llama 3.1"
        },
        "llama3.2": {
          "name": "Llama 3.2"
        },
        "mistral": {
          "name": "Mistral"
        },
        "codellama": {
          "name": "Code Llama",
          "tool_call": true
        },
        "deepseek-r1": {
          "name": "Deepseek r1"
        },
        "deepseek-r1:32b": {
          "name": "deepseek-r1:32b",
          "reasoning": true,
          "tools": true
        },
        "deepseek-coder-v2": {
          "name": "Deepseek Coder V2",
          "tool_call": true
        },
        "deepcoder": {
          "name": "DeepCoder",
          "tool_call": true
        },
        "dolphin3": {
          "name": "Dolphin 3"
        },
        "dolphin-mixtral": {
          "name": "Dolphin Mixtral",
          "tool_call": true
        },
        "openthinker": {
          "name": "Open Thinker",
          "tool_call": true
        },
        "mistral-nemo": {
          "name": "Mistral Nemo",
          "tool_call": true
        },
        "qwen2.5": {
          "name": "Qwen 2.5"
        },
        "qwq": {
          "name": "Qwq"
        },
        "codegemma": {
          "name": "CodeGemma"
        },
        "qwen2.5-coder": {
          "name": "Qwen 2.5 Coder"
        },
        "qwen3": {
          "name": "Qwen 3"
        },
        "qwen3-coder": {
          "name": "Qwen 3 Coder",
          "tool_call": true
        },
        "qwen3-coder:latest": {
          "name": "qwen3-coder:latest",
          "reasoning": true,
          "tools": true
        },
        "gemma3": {
          "name": "Gemma 3"
        }
      }
    }
  }
}
