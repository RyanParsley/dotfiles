{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "share": "disabled",

  "plugin": [
    "opencode-gemini-auth@latest",
    "~/.config/opencode/plugins/hook-guard.js",
    "~/.config/opencode/plugins/main-branch-guard.js",
    "~/.config/opencode/plugins/test-enforcement.js",
    "~/.config/opencode/plugins/lint-enforcement.js",
    "~/.config/opencode/plugins/tdd-enforcement.ts"
  ],

  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 50000
    },
    "firefox-devtools": {
      "type": "local",
      "command": ["npx", "-y", "firefox-devtools-mcp@latest", "--headless", "--viewport", "1280x720"],
      "enabled": true
    },
    "cerebro": {
      "type": "local",
      "command": ["cerebro", "mcp"],
      "enabled": true
    },
    "adrs": {
      "type": "local",
      "command": ["adrs", "mcp", "serve"],
      "enabled": true
    },
    "codeberg": {
      "type": "local",
      "command": ["forgejo-mcp", "--transport", "stdio", "--url", "https://codeberg.org"],
      "environment": {
        "FORGEJO_ACCESS_TOKEN": "{env:CODEBERG_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "forgejo": {
      "type": "local",
      "command": ["forgejo-mcp", "--transport", "stdio", "--url", "https://forgejo.parsley.familyds.com/"],
      "environment": {
        "FORGEJO_ACCESS_TOKEN": "{env:FORGEJO_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "dokploy-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@ahdev/dokploy-mcp"],
      "environment": {
        "DOKPLOY_URL": "https://dokploy.fretsome.com/api",
        "DOKPLOY_API_KEY": "{env:DOKPLOY_API_KEY}"
      },
      "enabled": true
    }
  },

  "provider": {
    "google": {
      "options": {
        "projectId": "opencode-493511"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-3n-e4b": { "name": "Gemma 3n-e4b (local)" },
        "ishumilin/deepseek-r1-coder-tools:8b": { "name": "Deepseek Coder Tools (8b)" },
        "olmo2": { "name": "OLMo 2" },
        "qwen3": { "name": "Qwen 3" },
        "qwen3-coder": { "name": "Qwen 3 Coder" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "kimi-k2.5:cloud": { "name": "kimi-k2.5:cloud" },
        "deepseek-r1:32b": { "name": "deepseek-r1:32b", "reasoning": true, "tool_call": true },
        "devstral:latest": { "name": "devstral:latest", "tool_call": true },
        "devstral-small-2:latest": { "name": "devstral-small-2:latest", "tool_call": true },
        "rnj-1:8b": { "name": "rnj-1:8b" },
        "ministral-3:8b": { "name": "ministral-3:8b" },
        "nemotron-3-nano:4b": { "name": "nemotron-3-nano:4b" },
        "qwen3.6:27b": { "name": "qwen3.6:27b" },
        "hf.co/unsloth/Qwen3.6-27B-GGUF:Q8_0": { "name": "Qwen3.6-27B-GGUF:Q8_0" },
        "functiongemma:270m": { "name": "functiongemma:270m" },
        "gemma4:26b": { "name": "gemma4:26b", "tool_call": true },
        "gpt-oss:latest": { "name": "gpt-oss:latest", "options": { "reasoning_effort": "high" } }
      }
    }
  },

  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  }
}
