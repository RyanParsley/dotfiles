{
  "$schema": "https://opencode.ai/config.json",

  // Container-specific opencode config.
  // Used inside dev containers via OPENCODE_CONFIG env var.
  // - share disabled, autoupdate on
  // - enabled_providers whitelist: only these show in the model menu
  // - Ollama and LM Studio point at host.docker.internal instead of 127.0.0.1
  // - JBH internal model endpoints included (URLs are not secrets)
  // - No MCPs — host-side tooling not available inside the container

  "autoupdate": true,
  "share": "disabled",
  "model": "github-copilot/claude-sonnet-4.6",

  // Only these provider IDs appear in the model menu.
  // All other providers (anthropic, openai, gemini, etc.) are suppressed.
  "enabled_providers": [
    "github-copilot",
    "ollama",
    "gemma4-e2b-dev",
    "gemma4-e2b-vllm-dev",
    "gemma4-e4b-vllm-dev",
    "gemma4-26b-dev",
    "mistral-nemo-dev"
  ],

  "provider": {
    "github-copilot": {
      // Auth handled by Copilot CLI credential store — no API key needed here
    },

    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (host)",
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1"
      },
      "models": {
        "gemma4:e2b":              { "name": "Gemma 4 E2B",          "tool_call": true },
        "gemma4:e4b":              { "name": "Gemma 4 E4B",          "tool_call": true },
        "gemma4:12b":              { "name": "Gemma 4 12b",          "tool_call": true },
        "gemma4:26b":              { "name": "Gemma 4 26b",          "tool_call": true },
        "gemma4:26b-mlx":          { "name": "Gemma 4 26b (MLX)",    "tool_call": true },
        "gemma4:latest":           { "name": "Gemma 4",              "tool_call": true },
        "mistral-small3.2:latest": { "name": "Mistral Small 3.2",    "tool_call": true },
        "devstral-small-2:latest": { "name": "Devstral Small 2",     "tool_call": true },
        "devstral:24b":            { "name": "Devstral 24b",         "tool_call": true },
        "ministral-3:14b":         { "name": "Ministral 3 14b" },
        "ministral-3:latest":      { "name": "Ministral 3" }
      }
    },

    // JBH GCP-hosted model endpoints
    "gemma4-e2b-dev": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma 4 E2B (JBH dev)",
      "options": {
        "baseURL": "http://gemma4-e2b-dev.nonprod.jbhunt.com/v1"
      },
      "models": {
        "gemma4:e2b": { "name": "Gemma 4 E2B (dev)", "tool_call": true }
      }
    },

    "gemma4-e2b-vllm-dev": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma 4 E2B vLLM (JBH dev)",
      "options": {
        "baseURL": "http://gemma4-e2b-vllm-dev.nonprod.jbhunt.com/v1"
      },
      "models": {
        "google/gemma-4-E2B-it": { "name": "Gemma 4 E2B vLLM (dev)", "tool_call": true }
      }
    },

    "gemma4-e4b-vllm-dev": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma 4 E4B vLLM (JBH dev)",
      "options": {
        "baseURL": "http://gemma4-e4b-vllm-dev.nonprod.jbhunt.com/v1"
      },
      "models": {
        "google/gemma-4-E4B-it": { "name": "Gemma 4 E4B vLLM (dev)", "tool_call": true }
      }
    },

    "mistral-nemo-dev": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral NeMo (JBH dev)",
      "options": {
        "baseURL": "http://mistral-nemo-dev.nonprod.jbhunt.com/v1"
      },
      "models": {
        "mistral-nemo:12b": { "name": "Mistral NeMo (dev)" }
      }
    },

    "gemma4-26b-dev": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma 4 26B (JBH dev)",
      "options": {
        "baseURL": "http://gemma4-26b-dev.nonprod.jbhunt.com/v1"
      },
      "models": {
        "gemma4:26b": { "name": "Gemma 4 26B (dev)", "tool_call": true }
      }
    }
  },

  // No MCPs in container context — host-side tooling not available
  "mcp": {}
}
